#!/usr/bin/env bash
# Pre-push hook: typecheck + test suite.
# Bypass with: git push --no-verify
set -euo pipefail

echo "[pre-push] tsc --noEmit"
if ! npx tsc --noEmit; then
  echo "[pre-push] Typecheck failed. Push aborted." >&2
  exit 1
fi

echo "[pre-push] vitest run --retry=2"
if ! npx vitest run --retry=2; then
  echo "[pre-push] Tests failed. Push aborted." >&2
  exit 1
fi

echo "[pre-push] OK"
