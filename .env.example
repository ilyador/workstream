# Server
# SUPABASE_MODE: local | cloud | custom
#   local  — Supabase running in Docker on this machine (http://127.0.0.1:54321)
#   cloud  — Hosted Supabase project (https://xxxx.supabase.co)
#   custom — Self-hosted Supabase on another machine or custom URL
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
PORT=3001
SUPABASE_MODE=local
WORKSTREAM_STEP_TIMEOUT_MINUTES=45
WORKSTREAM_QWEN_STEP_TIMEOUT_MINUTES=120

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Note: Frontend no longer needs VITE_SUPABASE_* vars (all calls go through Express)

# RAG (optional - for AI doc search flow)
LM_STUDIO_URL=http://localhost:1234
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# Google Drive sync (optional - for syncing docs into RAG)
GDRIVE_CREDENTIALS_PATH=/path/to/service-account.json
GDRIVE_FOLDER_ID=your-drive-folder-id
